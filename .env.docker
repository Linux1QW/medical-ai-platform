# ============================================
# Docker 部署环境变量模板
# ============================================
# 使用方法：复制此文件为 .env.docker 并填写配置
#   cp .env.docker .env
#   docker compose --env-file .env up -d
# ============================================

# ── MySQL 数据库 ──────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-secure-password-here
MYSQL_DATABASE=medical_ai

# ── Redis ─────────────────────────────────
REDIS_PORT=6379
REDIS_CHECKPOINT_URL=redis://redis:6379/1
REDIS_CHECKPOINT_TTL=86400

# ── JWT 安全 ──────────────────────────────
# 生产环境务必更换为随机字符串！
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── 阿里云百炼平台 Qwen API（必填） ──────
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max

# ── RAG 检索 ──────────────────────────────
ACTIVE_INDEX_VERSION=rag-v1
RERANK_MODEL=gte-rerank
LLM_MAX_CONCURRENT=10
LLM_SEMAPHORE_TIMEOUT=60

# ── LangGraph 编排 ────────────────────────
LANGGRAPH_ENABLED=true
LANGGRAPH_SHADOW_MODE=false

# ── Function Call / Tool Use ──────────────
ENABLE_TOOL_USE=false
TOOL_USE_MODEL=qwen-max
TOOL_USE_MAX_ROUNDS=4
TOOL_USE_MAX_CALLS=8
TOOL_USE_TIMEOUT_SECONDS=30
TOOL_USE_MAX_RESULT_CHARS=6000
KNOWLEDGE_TOOL_MAX_RAG_CALLS=3
KNOWLEDGE_TOOL_MAX_MQE_CALLS=2
KNOWLEDGE_TOOL_MAX_HYDE_CALLS=1
TOOL_USE_FALLBACK_TO_LEGACY=true

# ── 端口映射 ──────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=80
